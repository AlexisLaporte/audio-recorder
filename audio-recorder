#!/bin/bash
# audio-recorder - Record, transcribe & summarize audio

set -o pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Bootstrap
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_PATH="${BASH_SOURCE[0]}"
[ -L "$SCRIPT_PATH" ] && SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH")"
LIB_DIR="$(cd "$(dirname "$SCRIPT_PATH")/lib" && pwd)"

# shellcheck source=lib/config.sh
source "$LIB_DIR/config.sh"
# shellcheck source=lib/utils.sh
source "$LIB_DIR/utils.sh"
# shellcheck source=lib/audio.sh
source "$LIB_DIR/audio.sh"
# shellcheck source=lib/transcribe.sh
source "$LIB_DIR/transcribe.sh"
# shellcheck source=lib/trim.sh
source "$LIB_DIR/trim.sh"
# shellcheck source=lib/summarize.sh
source "$LIB_DIR/summarize.sh"
# shellcheck source=lib/push.sh
source "$LIB_DIR/push.sh"

load_config

# ─────────────────────────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────────────────────────

case "$1" in
    start)      cmd_start ;;
    stop)       shift; cmd_stop "$@" ;;
    status)     cmd_status ;;
    transcribe) shift; cmd_transcribe "$@" ;;
    summarize)  shift; cmd_summarize "$@" ;;
    trim|cut)   shift; cmd_trim "$@" ;;
    push)       shift; cmd_push "$@" ;;
    list|ls)    cmd_list ;;
    open)       cmd_open "$2" ;;
    setup)      setup ;;
    help|--help|-h) show_help ;;
    *)          show_help ;;
esac
